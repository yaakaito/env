{
  "language": "japanese",
  "env": {
    "MAX_THINKING_TOKENS": "31999",
    "ENABLE_LSP_TOOL": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(cp *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(gh api *)",
      "Bash(gh issue create *)",
      "Bash(gh issue edit *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(cd *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git log *)",
      "Bash(git pull *)",
      "Bash(git show *)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(git rm *)",
      "Bash(git stash *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(rg *)",
      "Bash(tail *)",
      "Bash(xargs grep *)",
      "Read(~/.claude/commands/commit.md)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:gist.githubusercontent.com)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/status-line.sh",
    "padding": 0
  },
  "respectGitignore": false,
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
